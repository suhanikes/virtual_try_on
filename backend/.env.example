PORT=3001

# Background removal mode:
# - removebg-api (default if bg_remover_api_key is set)
# - ml-service (legacy local Python service)
BG_REMOVE_MODE=removebg-api

# remove.bg API key
bg_remover_api_key=

# Optional override for remove.bg endpoint
REMOVE_BG_API_URL=https://api.remove.bg/v1.0/removebg

ML_SERVICE_URL=http://127.0.0.1:5000
ML_REQUEST_TIMEOUT_MS=300000
MAX_IMAGE_DIMENSION=3072
FRONTEND_URL=http://localhost:5173
